{
  "name": "server-node-express-rest-api-crud",
  "version": "0.1.0",
  "private": false,
  "description": "A Node.js/Express.js REST API server with full CRUD operations, Swagger documentation, Joi validation, and Winston logging. Integrates with dummy data API for rapid prototyping.",
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/starter-kits-2023.git"
  },
  "keywords": [
    "nodejs",
    "node.js",
    "express",
    "expressjs",
    "rest-api",
    "api",
    "crud",
    "swagger",
    "openapi",
    "joi",
    "validation",
    "winston",
    "logging",
    "middleware",
    "boilerplate",
    "starter-kit",
    "backend",
    "server",
    "javascript",
    "es6",
    "esm"
  ],
  "license": "MIT",
  "author": "Or Assayag <orassayag@gmail.com>",
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "main": "app.js",
  "files": [
    ".gitignore",
    "package-lock.json",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "NODE_ENV=local nodemon --watch src --ext js,yaml,json,ejs --ignore --exec node --es-module-specifier-resolution=node --inspect ./src/bin/www.js --source-maps DEBUG=metrics",
    "test": "mocha",
    "dev-test": "NODE_ENV=local npm run test"
  },
  "devDependencies": {
    "@babel/core": "^7.21.5",
    "@babel/eslint-parser": "^7.21.3",
    "@babel/plugin-syntax-import-assertions": "^7.20.0",
    "@types/node": "^18.16.3",
    "eslint": "^8.39.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "nodemon": "^2.0.22"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "express": "^4.18.2",
    "joi": "^17.9.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.2",
    "winston": "^3.8.2"
